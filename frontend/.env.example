# Конфигурация фронтенда kb-support (рабочее место оператора).
# Скопируйте в .env.local для локальной разработки. Реальные значения Keycloak —
# у ops/kb-auth (регистрация client'а фронта). Секреты в репозиторий НЕ коммитим.

# Секрет шифрования сессионного JWT (Auth.js). Сгенерировать: `openssl rand -base64 32`.
AUTH_SECRET=

# Keycloak client фронта (confidential), зарегистрированный в kb-auth.
AUTH_KEYCLOAK_ID=kb-support-frontend
AUTH_KEYCLOAK_SECRET=
# Issuer realm'а Keycloak (URL realm).
AUTH_KEYCLOAK_ISSUER=https://keycloak.rehome.local/realms/rehome

# Базовый URL API kb-support, к которому фронт ходит с Bearer.
KB_SUPPORT_API_BASE_URL=http://localhost:8000

# --- ВАЖНО (kb-auth / ops) -------------------------------------------------
# Access token, который Keycloak выдаёт этому client'у, ДОЛЖЕН содержать
# `aud: kb-support`, иначе бэкенд kb-support (#29, verify_aud) отклонит запрос.
# Требуется audience-mapper на client'е `kb-support-frontend` в Keycloak,
# добавляющий audience `kb-support` в access token.
# ---------------------------------------------------------------------------
